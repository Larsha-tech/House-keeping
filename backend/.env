# ──────────────────────────────────────────────────────────────────
# HOBB - Environment variables
# Copy this file to `.env` and fill in the values before `docker compose up`.
# ──────────────────────────────────────────────────────────────────

# --- App ---
APP_NAME=HOBB API
APP_ENV=production
APP_DEBUG=false

# --- PostgreSQL ---
POSTGRES_USER=hobb
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=hobb
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- JWT ---
# IMPORTANT: generate with: openssl rand -hex 48
JWT_SECRET=0e37b422c29ea355295417e12327c787234f7dbe6e5d5c73c98431a40aca913fd82280edc51e34a659c313c21c9103d6
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=20160

# --- CORS ---
# Comma-separated list of allowed origins
# For Docker self-hosting: add your server's IP/domain here, or use * to allow all origins.
# Example: CORS_ORIGINS=http://192.168.1.100,http://myserver.local
CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:5173,http://localhost:80

# --- File storage ---
# Path *inside the container* where uploads live
UPLOAD_DIR=/storage/uploads
MAX_UPLOAD_SIZE_MB=10
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
IMAGE_MAX_DIMENSION=2000
IMAGE_JPEG_QUALITY=85

# Host path / NAS mount that gets bound to /storage/uploads.
# Default is local ./storage/uploads for quick-start;
# in production point at your NAS: /mnt/nas/hobb/uploads
UPLOAD_VOLUME=./storage/uploads

# --- SMTP (set SMTP_ENABLED=true to actually send) ---
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@hobb.local
SMTP_USE_TLS=true

# --- Scheduler ---
SCHEDULER_ENABLED=true
MISSED_TASK_CHECK_INTERVAL_MINUTES=5
RECURRING_TASK_GENERATION_HOUR=0
REMINDER_LEAD_MINUTES=30

# --- Rate limiting ---
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_DEFAULT=120/minute

# --- Seed data ---
SEED_ON_STARTUP=true
SEED_ADMIN_EMAIL=admin@hobb.com
SEED_ADMIN_PASSWORD=admin123

# --- Logging ---
LOG_LEVEL=INFO
LOG_JSON=false

# --- Nginx ---
NGINX_HTTP_PORT=80
